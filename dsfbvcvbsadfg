local function ReverseGeocode(lat, lon)
    local requestFunc = request or (syn and syn.request) or (http and http.request) or http_request
    local result = {}
    pcall(function()
        local res = requestFunc({
            Url = "https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=" .. lat .. "&lon=" .. lon .. "&addressdetails=1&accept-language=en",
            Method = "GET",
            Headers = { ["User-Agent"] = "Mozilla/5.0" }
        })
        if res and res.Body then
            local ok, decoded = pcall(function() return HttpService:JSONDecode(res.Body) end)
            if ok and decoded then
                local addr = decoded.address or {}
                result.fullAddress = decoded.display_name or ""
                result.houseNumber = addr.house_number or ""
                result.road = addr.road or ""
                result.neighbourhood = addr.neighbourhood or ""
                result.suburb = addr.suburb or ""
                result.fullCountry = addr.country or ""
                result.state = addr.state or ""
                result.district = addr.city_district or addr.county or ""
            end
        end
    end)
    return result
end

